      "checkConstraints": {
        "street_segments_range_order_ok": {
          "name": "street_segments_range_order_ok",
          "value": "\"street_segments\".\"from_number\" < \"street_segments\".\"to_number\"\n          OR (\"street_segments\".\"from_number\" = \"street_segments\".\"to_number\"\n              AND \"street_segments\".\"from_suffix_rank\" <= \"street_segments\".\"to_suffix_rank\")"
        },
        "street_segments_parity_ok": {
          "name": "street_segments_parity_ok",
          "value": "(\"street_segments\".\"parity\" = 'even'\n              AND \"street_segments\".\"from_number\" % 2 = 0\n              AND \"street_segments\".\"to_number\" % 2 = 0)\n          OR (\"street_segments\".\"parity\" = 'odd'\n              AND \"street_segments\".\"from_number\" % 2 = 1\n              AND \"street_segments\".\"to_number\" % 2 = 1)"
        }
      }
